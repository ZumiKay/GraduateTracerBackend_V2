# =============================================
# GraduateTracer Backend — Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# --- Server ---
PORT=4000
NODE_ENV=DEV   # DEV | PROD | TEST

# --- Database ---
DATABASE_URL=mongodb://localhost:27017/graduatetracer

# --- Admin Credentials ---
ADMIN_EMAIL=admin@example.com
ADMIN_KEY=your-admin-secret-key

# --- JWT / Token Secrets ---
JWT_SECRET=your-jwt-secret-key
REFRESH_TOKEN_COOKIE=refresh_token
ACCESS_TOKEN_COOKIE=access_token

# --- Respondent Session ---
RESPONDENT_COOKIE=respondent_token
ACCESS_RESPONDENT_COOKIE=access_respondent_token
RESPONDENT_TOKEN_JWT_SECRET=your-respondent-jwt-secret

# --- RSA Keys (base64-encoded or file path) ---
RSA_PUBLIC_KEY=your-rsa-public-key
RSA_PRIVATE_KEY=your-rsa-private-key

# --- Google reCAPTCHA ---
RECAPCHA_SECRETKEY=your-recaptcha-secret-key

# --- Security ---
LOGIN_ATTEMPT=5   # Max failed login attempts before lockout

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password   # Use an App Password for Gmail
SMTP_FROM=your-email@gmail.com
EMAIL_APP_PASSWORD=your-email-app-password

# --- Frontend ---
FRONTEND_URL=http://localhost:5173

# --- Form Links ---
FORM_LINK_EXPIRATION=24   # Hours before invite links expire
INVITE_LINK_SECRET=your-invite-link-secret
